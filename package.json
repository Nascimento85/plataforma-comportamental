{
  "name": "plataforma-comportamental",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",

    "db:push": "prisma db push",
    "db:push:dev": "prisma db push --schema=prisma/schema.dev.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",

    "test:engines": "node tests/test-engines.mjs",
    "test": "npm run test:engines",

    "setup:dev": "npm run db:push:dev && npm run db:seed",
    "dev:local": "cp prisma/schema.dev.prisma prisma/schema.prisma && npm run setup:dev && npm run dev",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@react-pdf/renderer": "^3.4.0",
    "@sparticuz/chromium": "^123.0.1",
    "@stripe/stripe-js": "^3.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "next": "14.1.0",
    "bcryptjs": "^2.4.3",
    "next-auth": "^5.0.0-beta",
    "puppeteer-core": "^22.6.0",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^14.18.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5"
  }
}
