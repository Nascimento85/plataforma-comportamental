// ============================================================
// schema.prisma — PRODUÇÃO (PostgreSQL via Supabase)
// ============================================================
// Para desenvolvimento local, use schema.dev.prisma:
//   cp prisma/schema.dev.prisma prisma/schema.prisma
//   npx prisma db push && npm run db:seed
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // connection pooling (Supabase)
  directUrl = env("DIRECT_URL")     // conexão direta para migrations
}

// ============================================================
// EMPRESA (cliente do SaaS)
// ============================================================
model Company {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  type         String    @default("PJ") // PF | PJ
  phone        String?
  whatsapp     String?
  instagram    String?
  linkedin     String?
  birthDate    DateTime?

  // Endereço
  addressStreet String?
  addressCity   String?
  addressState  String?
  addressZip    String?

  // Dados profissionais
  jobTitle    String?
  companyName String?

  // Gamificação de onboarding
  isOnboardingCredited       Boolean @default(false)
  isProfileCompletedRewarded Boolean @default(false)

  active    Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees              Employee[]
  assessments            Assessment[]
  creditBalance          CreditBalance?
  creditPurchases        CreditPurchase[]
  creditTransactions     CreditTransaction[]
  reports                Report[]
  bundleReports          BundleReport[]
  profileValidationCodes ProfileValidationCode[]
  // Passaporte de Autoconhecimento
  bonusGrants       BonusGrant[]
  reportUnlocks     ReportUnlock[]
  scheduledOutreach ScheduledOutreach[]
}

// ============================================================
// CÓDIGO DE VALIDAÇÃO DE PERFIL (Gamificação +6 créditos)
// ============================================================
model ProfileValidationCode {
  id        String   @id @default(cuid())
  companyId String
  code      String   // 6 dígitos
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([code])
}

// ============================================================
// TOKEN DE RECUPERAÇÃO DE SENHA
// ============================================================
model PasswordResetToken {
  id        String   @id @default(cuid())
  companyId String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================================
// FUNCIONÁRIO / AVALIADO
// ============================================================
model Employee {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String
  createdAt DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id])
  assessments   Assessment[]
  bundleReports BundleReport[]

  @@unique([companyId, email])
}

// ============================================================
// AVALIAÇÃO (instância de um teste)
// ============================================================
model Assessment {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  testType    String    // DISC | MBTI | ENNEAGRAM | TEMPERAMENT
  token       String    @unique
  status      String    @default("PENDING") // PENDING | SENT | COMPLETED | EXPIRED
  bundleId    String?   // agrupa assessments de um bundle
  bundleOrder Int?      // ordem no bundle: 1=DISC, 2=MBTI, 3=ENNEAGRAM, 4=TEMPERAMENT
  expiresAt   DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  company            Company             @relation(fields: [companyId], references: [id])
  employee           Employee            @relation(fields: [employeeId], references: [id])
  discAnswers        DiscAnswer[]
  mbtiAnswers        MbtiAnswer[]
  enneagramAnswers   EnneagramAnswer[]
  temperamentAnswers TemperamentAnswer[]
  result             Result?
  report             Report?
}

// ============================================================
// RESPOSTAS por tipo de teste
// ============================================================
model DiscAnswer {
  id           String @id @default(cuid())
  assessmentId String
  groupId      Int
  profileD     Int
  profileI     Int
  profileS     Int
  profileC     Int

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}

model MbtiAnswer {
  id           String @id @default(cuid())
  assessmentId String
  questionId   Int
  scoreA       Int
  scoreB       Int

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}

model EnneagramAnswer {
  id           String @id @default(cuid())
  assessmentId String
  questionId   Int
  value        Int    // 1–5

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}

model TemperamentAnswer {
  id           String @id @default(cuid())
  assessmentId String
  questionId   Int
  selected     String // A | C | I | O

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}

// ============================================================
// RESULTADO CALCULADO
// ============================================================
model Result {
  id             String   @id @default(cuid())
  assessmentId   String   @unique
  testType       String
  resultData     Json     // PostgreSQL suporta Json nativo
  primaryProfile String
  createdAt      DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  report     Report?
}

// ============================================================
// RELATÓRIO PDF
// ============================================================
model Report {
  id           String   @id @default(cuid())
  assessmentId String   @unique
  resultId     String   @unique
  companyId    String
  pdfUrl       String?
  createdAt    DateTime @default(now())

  assessment Assessment    @relation(fields: [assessmentId], references: [id])
  result     Result        @relation(fields: [resultId], references: [id])
  company    Company       @relation(fields: [companyId], references: [id])
  unlock     ReportUnlock?
}

// ============================================================
// SISTEMA DE CRÉDITOS
// ============================================================
model CreditBalance {
  id        String   @id @default(cuid())
  companyId String   @unique
  // saldo PAGO (Stripe) — sem expiração
  balance   Int      @default(0)
  // saldo BÔNUS (passaporte/gamificação) — cache de SUM(bonusGrants.remaining)
  bonusBalance       Int       @default(0)
  bonusNextExpiresAt DateTime?
  passportStatus     String    @default("INACTIVE") // ACTIVE | EXPIRED | CONSUMED | INACTIVE
  updatedAt          DateTime  @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  bonusGrants BonusGrant[]

  @@index([bonusNextExpiresAt])
  @@index([passportStatus])
}

model CreditPurchase {
  id              String   @id @default(cuid())
  companyId       String
  stripeSessionId String   @unique
  amount          Int
  pricePaid       Int
  status          String   @default("PENDING") // PENDING | PAID | REFUNDED
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model CreditTransaction {
  id          String    @id @default(cuid())
  companyId   String
  type        String    // PURCHASE | DEBIT | BONUS | EXPIRE | REFUND
  source      String    @default("PAID") // PAID | BONUS
  amount      Int
  description String    @default("")
  expiresAt   DateTime? // preenchido em type=BONUS
  grantId     String?   // FK p/ BonusGrant (opcional)
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, type])
  @@index([expiresAt])
}

// ============================================================
// RELATÓRIO CRUZADO DE BUNDLE (devolutiva integrada dos 4 testes)
// ============================================================
model BundleReport {
  id          String   @id @default(cuid())
  bundleId    String   @unique        // mesmo bundleId dos 4 assessments
  companyId   String
  employeeId  String
  status      String   @default("PENDING") // PENDING | GENERATING | COMPLETED | FAILED
  content     String?  @db.Text            // JSON com seções do relatório gerado por IA
  pdfUrl      String?                      // URL do PDF no Supabase Storage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============================================================
// PASSAPORTE DE AUTOCONHECIMENTO — Bônus por lote (FIFO)
// Todo crédito não-comprado expira em 7 dias.
// ============================================================
model BonusGrant {
  id              String    @id @default(cuid())
  companyId       String
  creditBalanceId String
  source          String    // WELCOME_PASSPORT | PROFILE_COMPLETE | REFERRAL | GIFT | PROMO
  amount          Int
  remaining       Int
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime
  expiredAt       DateTime?
  description     String    @default("")

  creditBalance CreditBalance @relation(fields: [creditBalanceId], references: [id], onDelete: Cascade)
  company       Company       @relation(fields: [companyId], references: [id])

  @@index([companyId, expiresAt])
  @@index([companyId, remaining, expiresAt])
}

// ============================================================
// Premium gate — desbloqueio individual de relatório
// ============================================================
model ReportUnlock {
  id              String   @id @default(cuid())
  reportId        String   @unique
  companyId       String
  stripeSessionId String?  @unique
  amountBrl       Int
  unlockedAt      DateTime @default(now())

  report  Report  @relation(fields: [reportId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ============================================================
// Outreach (ManyChat) — agendamento e envio
// ============================================================
model ScheduledOutreach {
  id           String    @id @default(cuid())
  companyId    String
  type         String    // ZERO_BALANCE_DAY7 | FIRST_TEST_DAY7 | PASSPORT_EXPIRED
  scheduledFor DateTime
  sentAt       DateTime?
  status       String    @default("PENDING") // PENDING | SENT | FAILED | CANCELED
  attempts     Int       @default(0)
  payload      Json
  errorMsg     String?
  createdAt    DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([status, scheduledFor])
  @@index([companyId, type])
}
