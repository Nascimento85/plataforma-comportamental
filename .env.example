# ============================================================
# BANCO DE DADOS — Supabase PostgreSQL
# ============================================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ============================================================
# SUPABASE — Auth + Storage
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE_ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE_SERVICE_ROLE_KEY]"

# ============================================================
# NEXTAUTH — Autenticação
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[GERE_COM: openssl rand -base64 32]"

# ============================================================
# STRIPE — Pagamentos
# ============================================================
STRIPE_SECRET_KEY="sk_test_[...]"
STRIPE_WEBHOOK_SECRET="whsec_[...]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_[...]"

# Preços dos pacotes de créditos (IDs do Stripe)
STRIPE_PRICE_PACK_5="price_[...]"    # 5 créditos
STRIPE_PRICE_PACK_10="price_[...]"   # 10 créditos
STRIPE_PRICE_PACK_25="price_[...]"   # 25 créditos
STRIPE_PRICE_PACK_50="price_[...]"   # 50 créditos
STRIPE_PRICE_PACK_20="price_[...]"   # 20 créditos (alvo do cupom 50% off)

# Premium — Relatório individual + PDI
STRIPE_PRICE_PREMIUM_REPORT="price_[...]"
PREMIUM_REPORT_PRICE_CENTS="4700"          # R$ 47,00 (fallback se PRICE_ID ausente)
NEXT_PUBLIC_PREMIUM_PRICE_BRL="47,00"

# Cupom de re-engajamento (50% off no pacote de 20)
STRIPE_COUPON_50_OFF="PASSAPORTE50"

# ============================================================
# CRON (Railway/Vercel) — Bearer token p/ autorizar /api/cron/*
# ============================================================
CRON_SECRET="[GERE_COM: openssl rand -base64 32]"

# ============================================================
# MANYCHAT — Tags de perfil + outreach de re-engajamento
# ============================================================
# Token de API do ManyChat (Settings → API → Generate)
MANYCHAT_API_TOKEN="[manychat_token]"
# IDs dos Custom Fields criados no ManyChat
MANYCHAT_FIELD_EXTERNAL_ID="[field_id]"
MANYCHAT_FIELD_COUPON="[field_id]"
MANYCHAT_FIELD_COUPON_URL="[field_id]"
MANYCHAT_FIELD_TRIGGER="[field_id]"
MANYCHAT_FIELD_TEST_TYPE="[field_id]"
MANYCHAT_FIELD_PROFILE_KEY="[field_id]"
MANYCHAT_FIELD_RESULT_URL="[field_id]"
# Flow_ns do flow de re-engajamento (Cupom 50% off)
MANYCHAT_FLOW_REENGAGE="content_[...]"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Psique — Mapa Comportamental"

# ============================================================
# RESEND — E-mails transacionais
# ============================================================
# 1. Crie conta em https://resend.com (gratuito até 3.000/mês)
# 2. Domains → Add Domain → mapacomportamental.com
# 3. Cole os DNS records (TXT/MX/CNAME) no painel da GoDaddy
# 4. Verify no Resend (depois da propagação)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@mapacomportamental.com"
RESEND_FROM_NAME="Mapa Comportamental"

# E-mail do admin (recebe cópia das notificações de teste concluído)
ADMIN_EMAIL="kenio.araujo@live.com"
