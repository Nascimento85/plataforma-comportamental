# ============================================================
# BANCO DE DADOS — Supabase PostgreSQL
# ============================================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ============================================================
# SUPABASE — Auth + Storage
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE_ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE_SERVICE_ROLE_KEY]"

# ============================================================
# NEXTAUTH — Autenticação
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[GERE_COM: openssl rand -base64 32]"

# ============================================================
# STRIPE — Pagamentos
# ============================================================
STRIPE_SECRET_KEY="sk_test_[...]"
STRIPE_WEBHOOK_SECRET="whsec_[...]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_[...]"

# Preços dos pacotes de créditos (IDs do Stripe)
STRIPE_PRICE_PACK_5="price_[...]"    # 5 créditos
STRIPE_PRICE_PACK_10="price_[...]"   # 10 créditos
STRIPE_PRICE_PACK_25="price_[...]"   # 25 créditos
STRIPE_PRICE_PACK_50="price_[...]"   # 50 créditos

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Psique — Mapa Comportamental"

# ============================================================
# RESEND — E-mails transacionais
# ============================================================
# 1. Crie conta em https://resend.com (gratuito até 3.000/mês)
# 2. Domains → Add Domain → mapacomportamental.com
# 3. Cole os DNS records (TXT/MX/CNAME) no painel da GoDaddy
# 4. Verify no Resend (depois da propagação)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@mapacomportamental.com"
RESEND_FROM_NAME="Mapa Comportamental"

# E-mail do admin (recebe cópia das notificações de teste concluído)
ADMIN_EMAIL="kenio.araujo@live.com"
